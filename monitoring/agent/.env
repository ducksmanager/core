# Committed dev defaults, loaded via env_file by the dev compose (points at the
# local monitoring/grafana dev stack, no auth). On the server the prod compose
# reads a `.env` created MANUALLY; keep your copy of those production values
# locally in .env.prod.local (gitignored).
PROM_WRITE_URL=http://host.docker.internal:9090/api/v1/write
LOKI_WRITE_URL=http://host.docker.internal:3100/loki/api/v1/push
TRACES_WRITE_URL=http://host.docker.internal:4318
INGEST_USER=dev
INGEST_PASSWORD=dev
