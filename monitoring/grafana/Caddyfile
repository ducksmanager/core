{
    email admin@ducksmanager.net
}

# Grafana UI. Grafana handles its own authentication.
grafana.ducksmanager.net {
    reverse_proxy grafana:3000
}

# Ingest endpoint for the app-server Alloy agent (metrics + logs push).
# Protected by HTTP basic auth; credentials live in .env on this server.
ingest.ducksmanager.net {
    basic_auth {
        ingest {env.INGEST_BASICAUTH_HASH}
    }

    handle /api/v1/write* {
        reverse_proxy prometheus:9090
    }

    handle /loki/api/v1/push* {
        reverse_proxy loki:3100
    }

    handle {
        respond "Not found" 404
    }
}
