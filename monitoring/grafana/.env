# Committed dev defaults, loaded via env_file by the dev compose. On the server
# the prod compose reads a `.env` created MANUALLY; keep your copy of those
# production values locally in .env.prod.local (gitignored).
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=http://localhost:3000

# Alert emails -> mailcatcher (from packages/api/docker-compose-dev.yml, UI :1080).
GF_SMTP_ENABLED=true
GF_SMTP_HOST=host.docker.internal:1025
GF_SMTP_FROM_ADDRESS=alerts@ducksmanager.net
GF_SMTP_FROM_NAME=DucksManager Monitoring (dev)
GF_SMTP_SKIP_VERIFY=true
