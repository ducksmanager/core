{
  "apiVersion": "dashboard.grafana.app/v1alpha1",
  "kind": "Dashboard",
  "metadata": {
    "name": "dm-overview"
  },
  "spec": {
    "title": "DucksManager Overview",
    "tags": [
      "ducksmanager"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "editable": true,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "panels": [
      {
        "type": "row",
        "title": "Availability (probed from the monitoring server)",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        }
      },
      {
        "type": "stat",
        "title": "Endpoint up",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 1
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "probe_success",
            "legendFormat": "{{instance}}",
            "instant": true
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Healthcheck response time",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 16,
          "x": 8,
          "y": 1
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "probe_http_duration_seconds",
            "legendFormat": "{{instance}} — {{phase}}"
          }
        ]
      },
      {
        "type": "row",
        "title": "Host",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 7
        }
      },
      {
        "type": "timeseries",
        "title": "CPU usage %",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 8,
          "x": 0,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "cpu"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Memory usage %",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 8,
          "x": 8,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
            "legendFormat": "memory"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Disk usage % (per mount)",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 8,
          "x": 16,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "100 * (1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"})",
            "legendFormat": "{{mountpoint}}"
          }
        ]
      },
      {
        "type": "row",
        "title": "Containers",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 15
        }
      },
      {
        "type": "timeseries",
        "title": "Container memory",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "container_memory_usage_bytes{name!=\"\"}",
            "legendFormat": "{{name}}"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Container CPU",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))",
            "legendFormat": "{{name}}"
          }
        ]
      },
      {
        "type": "row",
        "title": "Caddy / HTTP",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 23
        }
      },
      {
        "type": "timeseries",
        "title": "Request rate",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 0,
          "y": 24
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum by (handler) (rate(caddy_http_requests_total[5m]))",
            "legendFormat": "{{handler}}"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Request duration p95",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 7,
          "w": 12,
          "x": 12,
          "y": 24
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.95, sum by (le) (rate(caddy_http_request_duration_seconds_bucket[5m])))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "type": "row",
        "title": "Pastec index",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 31
        }
      },
      {
        "type": "stat",
        "title": "Pastec index — images",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 32
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "pastec_index_images",
            "instant": true
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Pastec index size over time",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 16,
          "x": 8,
          "y": 32
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "pastec_index_images",
            "legendFormat": "images"
          }
        ]
      },
      {
        "type": "row",
        "title": "Pastec search latency",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 38
        }
      },
      {
        "type": "stat",
        "title": "Search response time — server 0",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 0,
          "y": 39
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 3
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "probe_duration_seconds{instance=\"https://api.ducksmanager.net/status/pastecsearch/0\"}",
            "instant": true
          }
        ]
      },
      {
        "type": "stat",
        "title": "Search response time — server 1 (kp1000-flann200)",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 4,
          "y": 39
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 3
                }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "probe_duration_seconds{instance=\"https://api.ducksmanager.net/status/pastecsearch/1\"}",
            "instant": true
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Search response time over time",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 6,
          "w": 16,
          "x": 8,
          "y": 39
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "probe_duration_seconds{job=\"pastec-search-latency\"}",
            "legendFormat": "{{instance}}"
          }
        ]
      },
      {
        "type": "row",
        "title": "Logs",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 45
        }
      },
      {
        "type": "logs",
        "title": "Container logs",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "gridPos": {
          "h": 12,
          "w": 24,
          "x": 0,
          "y": 46
        },
        "options": {
          "showTime": true,
          "wrapLogMessage": true,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "loki",
              "uid": "loki"
            },
            "expr": "{container=~\".+\"}"
          }
        ]
      }
    ]
  }
}
