{
  "name": "~monitoring-grafana",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "docker compose -f docker-compose-dev.yml up --force-recreate",
    "dashboards:pull": "bash bin/dashboards-pull.sh",
    "prod:build-docker-grafana": "REPO_NAME=ghcr.io/bperel/monitoring-grafana pnpm -F '~ci' prod:build-docker --target grafana -f monitoring/grafana/Dockerfile",
    "prod:build-docker-prometheus": "REPO_NAME=ghcr.io/bperel/monitoring-prometheus pnpm -F '~ci' prod:build-docker --target prometheus -f monitoring/grafana/Dockerfile",
    "prod:build-docker-loki": "REPO_NAME=ghcr.io/bperel/monitoring-loki pnpm -F '~ci' prod:build-docker --target loki -f monitoring/grafana/Dockerfile",
    "prod:build-docker-blackbox": "REPO_NAME=ghcr.io/bperel/monitoring-blackbox pnpm -F '~ci' prod:build-docker --target blackbox -f monitoring/grafana/Dockerfile",
    "prod:build-docker-json-exporter": "REPO_NAME=ghcr.io/bperel/monitoring-json-exporter pnpm -F '~ci' prod:build-docker --target json-exporter -f monitoring/grafana/Dockerfile",
    "prod:build-docker-tempo": "REPO_NAME=ghcr.io/bperel/monitoring-tempo pnpm -F '~ci' prod:build-docker --target tempo -f monitoring/grafana/Dockerfile",
    "prod:build-docker": "pnpm run '/^prod:build-docker-/'",
    "prod:transfer-files-post": "pnpm -F '~ci' prod:transfer-files monitoring/grafana/docker-compose.yml:@monitoring/grafana/docker-compose.yml monitoring/grafana/grafana.conf:@monitoring/grafana/grafana.conf",
    "prod:deploy": "DIR=monitoring/grafana pnpm -F '~ci' prod:docker-compose-up"
  }
}
