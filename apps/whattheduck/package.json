{
  "name": "~whattheduck",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "cap:update": "cap update",
    "capacitor-assets": "capacitor-assets generate && pnpm optimize-splash-images",
    "optimize-splash-images": "bun run scripts/optimize-splash.ts",
    "dev": "pnpm cap:update && pnpm dev:server",
    "dev:server": "concurrently -n vite,vue-tsc \"vite --port 8008 --host\" \"vue-tsc --noEmit --watch\"",
    "dev:android": "bun run scripts/dev-android.ts",
    "lint": "eslint --fix .",
    "set-android-socket-url": "bun run scripts/set-android-socket-url.ts",
    "update-android-capacitor-config": "bun run scripts/update-android-capacitor-config.ts",
    "build": "vite build && vue-tsc --noEmit && pnpm sentry:sourcemaps && pnpm cleanup-sourcemaps",
    "cleanup-sourcemaps": "find dist -name '*.map' -type f -delete",
    "prod:deploy-get-previous-release": "gh release list --json name,tagName --jq 'map(select(.name | startswith(\"WhatTheDuck\")))[0]' | jq -r '.tagName'",
    "prod:deploy": "export DATE=$(date +'%Y-%m-%dT%H%M%S'); export BUNDLE_FILE=whattheduck-bundle-$DATE.zip; pnpm bundle-capgo && pnpm prod:deploy-create-release && pnpm prod-deploy-update-latest-bundle",
    "prod-deploy-update-latest-bundle": "echo https://github.com/ducksmanager/core/releases/download/whattheduck-$DATE/$BUNDLE_FILE > latest-whattheduck-bundle.txt && pnpm -F '~ci' prod:transfer-files apps/whattheduck/latest-whattheduck-bundle.txt:@packages/api/latest-whattheduck-bundle.txt",
    "prod:deploy-create-release": "gh release create --title \"WhatTheDuck bundle $DATE\" --generate-notes whattheduck-$DATE $BUNDLE_FILE",
    "bundle-capgo": "capgo bundle zip --package-json package.json --name $BUNDLE_FILE",
    "ionic:build": "pnpm build",
    "preview": "vite preview",
    "story:dev": "histoire dev",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org bruno-perel --project whattheduck ./dist && sentry-cli sourcemaps upload --org bruno-perel --project whattheduck ./dist"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/clipboard": "^8.0.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capawesome/capacitor-android-edge-to-edge-support": "^8.0.6",
    "@capawesome/capacitor-app-update": "^8.0.3",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@capgo/camera-preview": "^8.2.2",
    "@capgo/capacitor-updater": "^8.45.1",
    "@ionic/pwa-elements": "^3.4.0",
    "@ionic/storage": "^4.0.0",
    "@ionic/vue": "^8.8.3",
    "@ionic/vue-router": "^8.8.3",
    "@nanoandrew4/vue3-carousel-3d": "^1.0.2",
    "@sentry/capacitor": "^3.2.0",
    "@sentry/vue": "10.43.0",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "axios-cache-interceptor": "^1.12.0",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.20",
    "ionicons": "^8.0.13",
    "js-cookie": "^3.0.5",
    "pinia": "^3.0.4",
    "sass": "^1.98.0",
    "socket-call-client": "^0.7.7",
    "universal-cookie": "^7.2.2",
    "vue": "^3.5.31",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vue-virtual-scroller": "2.0.0-beta.8",
    "~dm-types": "workspace:*",
    "~group-by": "workspace:*",
    "~prisma-schemas": "workspace:*",
    "~web": "workspace:*"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capgo/cli": "^7.88.9",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@intlify/unplugin-vue-i18n": "^11.1.1",
    "@ionic/cli": "^7.2.1",
    "@ionic/prettier-config": "^4.0.0",
    "@sentry/cli": "^2.58.5",
    "@types/imagemin": "9.0.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue-macros/reactivity-transform": "^3.1.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier-vue": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "glob": "^10.5.0",
    "globals": "^15.15.0",
    "histoire": "1.0.0-beta.1",
    "imagemin": "9.0.1",
    "imagemin-pngquant": "9.0.1",
    "jsdom": "^24.1.3",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.1.0",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.0",
    "vue-tsc": "^3.2.6"
  },
  "description": "What The Duck",
  "prettier": "@ionic/prettier-config"
}