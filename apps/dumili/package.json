{
  "name": "~dumili",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=26.0.0 <27.0.0"
  },
  "scripts": {
    "build": "vite build && pnpm sentry:sourcemaps && pnpm build-storybook",
    "build-storybook": "storybook build",
    "dumili": "concurrently -p \"[dumili-{name}]\" --kill-others-on-fail -n front,api,dm,kumiko+paddleocr \"pnpm -F ~dumili dev\" \"pnpm -F ~dumili-api dev\" \"pnpm -F ~web web\" \"docker compose -f docker-compose-dev.yml up kumiko db\"",
    "dev": "concurrently -n vite,vue-tsc \"vite --port 8004\" \"vue-tsc --noEmit --watch\"",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint --fix .",
    "prod:deploy": "DIR=apps/dumili pnpm -F '~ci' prod:docker-compose-up",
    "prod:build-docker-storybook": "REPO_NAME=ghcr.io/bperel/dumili-storybook pnpm -F '~ci' prod:build-docker --target storybook -f apps/dumili/Dockerfile",
    "prod:build-docker-web": "REPO_NAME=ghcr.io/bperel/dumili-app pnpm -F '~ci' prod:build-docker --target web -f apps/dumili/Dockerfile",
    "prod:build-docker": "pnpm run '/^prod:build-docker-/'",
    "prod:transfer-files-pre": "pnpm -F '~ci' prod:transfer-files @apps/dumili/.env:apps/dumili/.env",
    "prod:transfer-files-post": "pnpm -F '~ci' prod:transfer-files apps/dumili/docker-compose.yml:@apps/dumili/docker-compose.yml apps/dumili/Caddyfile:@apps/dumili/Caddyfile apps/dumili/config/sentry-relay/projects/4508868506222592.json:@apps/dumili/config/sentry-relay/projects/4508868506222592.json apps/dumili/config/sentry-relay/config.yml:@apps/dumili/config/sentry-relay/config.yml",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org bruno-perel --project dumili ./dist && sentry-cli sourcemaps upload --org bruno-perel --project dumili ./dist",
    "storybook": "NODE_ENV=development storybook dev -p 6006",
    "test-storybook": "test-storybook --config-dir .storybook --ci --failOnConsole --testTimeout=30000",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@prisma/adapter-mariadb": "^7.9.0",
    "@sentry/browser": "^10.67.0",
    "@sentry/vue": "^10.67.0",
    "@unhead/vue": "^1.11.20",
    "@uppy/core": "5.2.0",
    "@uppy/dashboard": "5.1.1",
    "@uppy/image-editor": "4.2.0",
    "@uppy/webcam": "5.1.0",
    "@uppy/xhr-upload": "^5.2.0",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios-cache-interceptor": "^1.12.1",
    "bootstrap": "^5.3.8",
    "bootstrap-vue-next": "^0.45.8",
    "js-cookie": "^3.0.8",
    "pinia": "^3.0.4",
    "socket-call-client": "^0.7.7",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.40",
    "vue-draggable-resizable": "^3.0.0",
    "vue-i18n": "^11.4.7",
    "vue-router": "^5.2.0",
    "~group-by": "workspace:*",
    "~web": "workspace:*"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@playwright/test": "^1.61.1",
    "@sentry/cli": "^3.6.2",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/test-runner": "^0.24.4",
    "@storybook/vue3-vite": "^10.5.3",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^26.1.1",
    "@types/sortablejs": "^1.15.9",
    "@types/vue-draggable-resizable": "^3.0.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-prettier-vue": "^5.0.0",
    "eslint-plugin-storybook": "^10.5.3",
    "eslint-plugin-vue": "^10.10.0",
    "prettier": "^3.9.6",
    "sass": "^1.101.3",
    "storybook": "^10.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.5",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vue-tsc": "^3.3.8"
  },
  "pnpm": {
    "overrides": {
      "rolldown": "1.0.1"
    }
  }
}