{
  "compilerOptions": {
    "declaration": true,
    "module": "ESNext",
    "target": "ES2023",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "strictNullChecks": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "../..",
    "paths": {
      "~group-by": [
        "../../util/group-by"
      ]
    },
  },
  "exclude": [
    "node_modules",
    "client_*",
    ".turbo",
    "eslint.config.mjs"
  ]
}