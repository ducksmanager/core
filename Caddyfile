{
    debug
    email admin@ducksmanager.net
	log default {
		output stdout
		format json
		include http.log.access
	}
	# Collect per-server HTTP metrics (opt-in because of the overhead).
	servers {
		metrics
	}
}

# Prometheus metrics
# 2020 is not published to the host — only reachable by containers on the shared Docker networks, which is where the agent scrapes caddy:2020/metrics.
:2020 {
	metrics /metrics
}

import /etc/caddy/apps/*/Caddyfile
import /etc/caddy/apps/dm/apps/*/Caddyfile
import /etc/caddy/apps/dm/apps/*/api/Caddyfile
import /etc/caddy/apps/dm/packages/*/Caddyfile